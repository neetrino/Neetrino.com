generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model BlogPost {
  id            String                @id @default(cuid())
  coverImageUrl String?               @map("cover_image_url")
  coverImageKey String?               @map("cover_image_key")
  status        String                @default("DRAFT")
  publishedAt   DateTime?             @map("published_at")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  translations  BlogPostTranslation[]

  @@map("blog_posts")
}

model BlogPostTranslation {
  id             String   @id @default(cuid())
  blogPostId     String   @map("blog_post_id")
  locale         String
  title          String
  slug           String
  excerpt        String
  content        String
  imageAlt       String?  @map("image_alt")
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  blogPost       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, locale])
  @@unique([locale, slug])
  @@map("blog_post_translations")
}

model PortfolioAsset {
  id          String   @id @default(cuid())
  title       String
  alt         String
  assetType   String   @default("IMAGE") @map("asset_type")
  status      String   @default("ACTIVE")
  sortOrder   Int      @default(0) @map("sort_order")
  key         String   @unique
  url         String
  /** Optional Slack / live project URL opened from the portfolio card action. */
  projectUrl  String?  @map("project_url")
  contentType String   @map("content_type")
  sizeBytes   Int      @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("portfolio_assets")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model PaymentProduct {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceAmd    Int      @map("price_amd")
  type        String   @default("ONE_TIME")
  status      String   @default("ACTIVE")
  secretSlug  String   @unique @map("secret_slug")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  attempts    PaymentAttempt[]

  @@map("payment_products")
}

model PaymentAttempt {
  id                    String         @id @default(cuid())
  productId             String         @map("product_id")
  status                String         @default("PENDING")
  provider              String         @default("ARCA")
  amountAmd             Int            @map("amount_amd")
  currency              String         @default("AMD")
  providerTransactionId String?        @unique @map("provider_transaction_id")
  redirectUrl           String?        @map("redirect_url")
  providerResponse      Json?          @map("provider_response")
  failureMessage        String?        @map("failure_message")
  paidAt                DateTime?      @map("paid_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  product               PaymentProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([status])
  @@map("payment_attempts")
}
